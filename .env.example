# GitHub Organization / User Configuration
GH_OWNER=qltechin
GH_ACCOUNT_TYPE=user  # 'user' for personal account, 'organization' for org
GH_PROJECT_NUMBER=1
GH_AGENTS_REPO_NAME=agents

# Monitored Repositories (comma-separated, format: owner/repo)
MONITORED_REPOS=qltechin/app

# Builder Agent Repos (comma-separated)
BUILDER_REPOS=qltechin/app

# GitHub Configuration
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=qltechin/app

# ── LLM Configuration (orchestration / analysis) ──────────────────────────────
# Option 1: Direct Anthropic API (recommended)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Option 2: AWS Bedrock
# LLM_PROVIDER=bedrock
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-6-20251001-v1:0
# BEDROCK_REGION=us-east-1

# Option 3: Cerebras z.ai (GLM 4.7 - ultra-fast inference)
# LLM_PROVIDER=cerebras
# CEREBRAS_API_KEY=csk-xxx
# CEREBRAS_MODEL=glm-4.7

# ── Code Agent Configuration (autonomous code generation) ─────────────────────
# Controls which agent writes the actual code fixes inside the builder.
# Set CODE_AGENT_PROVIDER to one of: claude, deepseek, codex, auto
# 'auto' picks the first available key: claude → deepseek → codex
CODE_AGENT_PROVIDER=auto

# Option 1: Claude (uses ANTHROPIC_API_KEY above, model below)
# CLAUDE_CODE_MODEL=claude-sonnet-4-6

# Option 2: DeepSeek  (cheap, fast — ~$0.001/1k tokens)
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat

# Option 3: Codex CLI (requires ChatGPT Plus / Pro subscription)
# CODEX_AUTH_JSON={"accessToken": "xxx", "refreshToken": "yyy"}

# Langfuse Observability (optional)
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# Agent Configuration
DRY_RUN=false
VERBOSE=false

# Figma Integration (optional, for Designer Agent)
# FIGMA_ACCESS_TOKEN=figd_xxx
# FIGMA_TEAM_ID=xxx
# FIGMA_DEFAULT_FILE_KEY=abc123

# Google Chat Integration (optional)
# GOOGLE_CHAT_SPACE_AI_BUILDERS=spaces/AAAAxxx
# GOOGLE_CHAT_SPACE_INFRASTRUCTURE=spaces/AAAAxxx
# GOOGLE_CHAT_ENABLED=true
